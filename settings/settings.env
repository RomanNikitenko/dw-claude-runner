#!/bin/bash
#
# This file was generated using AI assistance (Cursor AI)
# and reviewed by the maintainers.
#

# Time (seconds) to wait for DevWorkspace to reach 'Running' state
export TIMEOUT=${TIMEOUT:-300}

# Time (seconds) to wait for Claude to complete the task
export CLAUDE_TIMEOUT=${CLAUDE_TIMEOUT:-3000}

# DevWorkspace instance name
export DEVWORKSPACE_NAME=${DEVWORKSPACE_NAME:-'claude-runner'}

# Container image (lightweight Node.js on UBI9)
export CONTAINER_IMAGE=${CONTAINER_IMAGE:-'registry.access.redhat.com/ubi9/nodejs-22:9.7'}

# Project repository to clone into the workspace
export PROJECT_URL=${PROJECT_URL:-'"https://github.com/RomanNikitenko/web-nodejs-sample.git"'}

# Editor definition (che-code / vscode)
export EDITOR_DEFINITION=${EDITOR_DEFINITION:-'https://raw.githubusercontent.com/eclipse-che/che-operator/refs/heads/main/editors-definitions/che-code-insiders.yaml'}

# Claude Code version to install
export CLAUDE_VERSION=${CLAUDE_VERSION:-'2.1.92'}

# GitHub issue URL to resolve (required, no default — must be provided via env)
export ISSUE_REF=${ISSUE_REF:-}

# Target GitHub repo (owner/name)
export TARGET_REPO=${TARGET_REPO:-'RomanNikitenko/web-nodejs-sample'}

# Validate that the workspace is ready for Claude
validate_devworkspace() {
  resolve_devworkspace_pod || return 1

  # Check shell access
  echo -e "  Checking shell access..."
  if ! oc exec -n ${DEVWORKSPACE_NS} ${podName} -c ${mainContainerName} -- bash -c "echo ok" 2>/dev/null; then
    echo -e "  ${YELLOW}bash not available, trying sh...${NC}"
    if ! oc exec -n ${DEVWORKSPACE_NS} ${podName} -c ${mainContainerName} -- sh -c "echo ok" 2>/dev/null; then
      echo -e "  ${RED}Cannot exec into container${NC}"
      if [ ${DEBUG:-0} -eq 1 ]; then
        echo -e "  ${YELLOW}Container statuses:${NC}"
        oc get pod ${podName} -n ${DEVWORKSPACE_NS} -o json | jq '.status.containerStatuses[] | {name, ready, state}' 2>/dev/null
      fi
      return 1
    fi
  fi
  echo -e "  ${GREEN}Shell access: OK${NC}"

  # List /projects to see what's there
  if [ ${DEBUG:-0} -eq 1 ]; then
    echo -e "  Listing /projects/..."
    oc exec -n ${DEVWORKSPACE_NS} ${podName} -c ${mainContainerName} -- ls -la /projects/ 2>/dev/null || echo "  (cannot list /projects/)"
  fi

  # Wait for project to be cloned
  echo -e "  Waiting for project clone..."
  local clone_attempts=0
  local clone_max=30
  while [ ${clone_attempts} -lt ${clone_max} ]; do
    if oc exec -n ${DEVWORKSPACE_NS} ${podName} -c ${mainContainerName} -- test -d /projects/${PROJECT_NAME}/.git 2>/dev/null; then
      echo -e "  ${GREEN}Project cloned${NC}"
      break
    fi
    sleep 2
    clone_attempts=$((clone_attempts + 1))
    [ $((clone_attempts % 5)) -eq 0 ] && echo -e "  ... attempt ${clone_attempts}/${clone_max}"
  done

  if [ ${clone_attempts} -ge ${clone_max} ]; then
    echo -e "  ${RED}Project not cloned after ${clone_max} attempts${NC}"
    if [ ${DEBUG:-0} -eq 1 ]; then
      echo -e "  ${YELLOW}/projects/ contents:${NC}"
      oc exec -n ${DEVWORKSPACE_NS} ${podName} -c ${mainContainerName} -- ls -la /projects/ 2>/dev/null || echo "  (cannot list)"
      echo -e "  ${YELLOW}Git credentials:${NC}"
      oc exec -n ${DEVWORKSPACE_NS} ${podName} -c ${mainContainerName} -- ls -la /.git-credentials/ 2>/dev/null || echo "  (no git credentials mounted)"
    fi
    return 1
  fi

  echo -e "  ${GREEN}Workspace validated: container accessible, project cloned${NC}"
  return 0
}
